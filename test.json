    {
      "name": "Signin (Shared)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Signin returns 200', function () { pm.response.to.have.status(200); });",
              "let json = pm.response.json();",
              "let role = pm.collectionVariables.get('CURRENT_ROLE');",
              "if (json && json.data && json.data.token) {",
              "  pm.collectionVariables.set('CURRENT_TOKEN', json.data.token);",
              "  if (role === 'admin') {",
              "    pm.collectionVariables.set('TOKEN_ADMIN', json.data.token);",
              "    pm.collectionVariables.set('ADMIN_ID', (json.data.user && (json.data.user.id || json.data.user._id)) || pm.collectionVariables.get('ADMIN_ID'));",
              "  } else {",
              "    pm.collectionVariables.set('TOKEN_CUSTOMER', json.data.token);",
              "    pm.collectionVariables.set('CUSTOMER_ID', (json.data.user && (json.data.user.id || json.data.user._id)) || pm.collectionVariables.get('CUSTOMER_ID'));",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
