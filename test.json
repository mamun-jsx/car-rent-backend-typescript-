{
  "info": {
    "_postman_id": "B6A2_Rbac_Auto_Switch",
    "name": "B6A2",
    "description": "Full RBAC test collection. Auto-signup uses timestamped emails so signup runs every execution.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "B6A2_Rbac_Auto_Switch"
  },
  "item": [
    {
      "name": "Initialize Variables",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Initialize core vars and choose signup mode A (auto timestamped) by default",
              "if (!pm.collectionVariables.get('SIGNUP_MODE')) pm.collectionVariables.set('SIGNUP_MODE','A');",
              "pm.collectionVariables.set('CURRENT_ROLE','admin');",
              "",
              "// Create timestamp suffix for emails when SIGNUP_MODE === 'A'",
              "let ts = Math.floor(Date.now()/1000);",
              "pm.collectionVariables.set('TS', ts.toString());",
              "",
              "if (pm.collectionVariables.get('SIGNUP_MODE') === 'A') {",
              "  pm.collectionVariables.set('ADMIN_EMAIL', 'admin+' + pm.collectionVariables.get('TS') + '@example.com');",
              "  pm.collectionVariables.set('CUSTOMER_EMAIL', 'customer+' + pm.collectionVariables.get('TS') + '@example.com');",
              "} else {",
              "  // keep whatever is set",
              "  if (!pm.collectionVariables.get('ADMIN_EMAIL')) pm.collectionVariables.set('ADMIN_EMAIL','admin@example.com');",
              "  if (!pm.collectionVariables.get('CUSTOMER_EMAIL')) pm.collectionVariables.set('CUSTOMER_EMAIL','customer@example.com');",
              "}",
              "",
              "// default other fields if not set",
              "if (!pm.collectionVariables.get('ADMIN_NAME')) pm.collectionVariables.set('ADMIN_NAME','Admin User');",
              "if (!pm.collectionVariables.get('ADMIN_PASSWORD')) pm.collectionVariables.set('ADMIN_PASSWORD','admin123');",
              "if (!pm.collectionVariables.get('ADMIN_PHONE')) pm.collectionVariables.set('ADMIN_PHONE','01711111111');",
              "if (!pm.collectionVariables.get('CUSTOMER_NAME')) pm.collectionVariables.set('CUSTOMER_NAME','Customer User');",
              "if (!pm.collectionVariables.get('CUSTOMER_PASSWORD')) pm.collectionVariables.set('CUSTOMER_PASSWORD','customer123');",
              "if (!pm.collectionVariables.get('CUSTOMER_PHONE')) pm.collectionVariables.set('CUSTOMER_PHONE','01722222222');",
              "",
              "// set login placeholders for first signin (admin)",
              "pm.collectionVariables.set('LOGIN_EMAIL', pm.collectionVariables.get('ADMIN_EMAIL'));",
              "pm.collectionVariables.set('LOGIN_PASSWORD', pm.collectionVariables.get('ADMIN_PASSWORD'));",
              ""
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Initialization ok', function() {",
              "  pm.expect(pm.collectionVariables.get('CURRENT_ROLE')).to.eql('admin');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/",
          "host": ["{{BASE_URL}}"],
          "path": [""]
        }
      },
      "response": []
    },
    {
      "name": "Signup (Admin)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Admin signup returns 201 or 400/409 if already exists', function() {",
              "  pm.expect(pm.response.code).to.be.oneOf([201,400,409]);",
              "});",
              "try {",
              "  let j = pm.response.json();",
              "  if (j && j.data && (j.data.id || j.data._id)) {",
              "    pm.collectionVariables.set('ADMIN_ID', j.data.id || j.data._id);",
              "  }",
              "} catch (e) { console.log('No JSON or no id in signup response', e); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{ADMIN_NAME}}\",\n  \"email\": \"{{ADMIN_EMAIL}}\",\n  \"password\": \"{{ADMIN_PASSWORD}}\",\n  \"phone\": \"{{ADMIN_PHONE}}\",\n  \"role\": \"admin\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
