      "name": "Create Booking (Customer - Success)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.collectionVariables.get('FUTURE_START')) {",
              "  let s = new Date(); s.setDate(s.getDate() + 7);",
              "  let e = new Date(); e.setDate(e.getDate() + 10);",
              "  function toYMD(d){return d.getFullYear() + '-' + ('0'+(d.getMonth()+1)).slice(-2) + '-' + ('0'+d.getDate()).slice(-2);}",
              "  pm.collectionVariables.set('FUTURE_START', toYMD(s));",
              "  pm.collectionVariables.set('FUTURE_END', toYMD(e));",
              "}"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Create booking -> 201', function() { pm.response.to.have.status(201); });",
              "try {",
              "  let j = pm.response.json();",
              "  console.log('Booking response:', JSON.stringify(j));",
              "  let bookingId = null;",
              "  if (j && j.data) {",
              "    bookingId = j.data.id || j.data._id || j.data.booking_id;",
              "  } else if (j && (j.id || j._id)) {",
              "    bookingId = j.id || j._id;",
              "  }",
              "  if (bookingId) {",
              "    pm.collectionVariables.set('BOOKING_ID', bookingId);",
              "    console.log('✅ BOOKING_ID set to:', bookingId);",
              "  } else {",
              "    console.log('⚠️ Could not extract booking ID from response');",
              "  }",
              "} catch (e) {",
              "  console.log('❌ Error parsing booking response:', e);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
